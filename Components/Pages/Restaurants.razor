@page "/restaurants"
@rendermode InteractiveServer

<PageTitle>Restaurants</PageTitle>

<CardGroup Class="d-flex flex-wrap gap-4 mb-4">
    @foreach (var restaurant in RestaurantList)
    {
        <a href="@restaurant.MapSearchUrl" target="_blank" rel="noopener noreferrer" class="text-decoration-none text-body">
            <Card Class="h-100 shadow-sm" Style="width:18rem;">
                <img src="@restaurant.ImageUrl" alt="@restaurant.ImageAlt" style="height: 200px; object-fit: cover;" />
                <CardBody>
                    <CardTitle>@restaurant.Title</CardTitle>
                    <CardText>@restaurant.Description</CardText>
                    <CardText Class="text-muted">Last updated @restaurant.LastUpdated</CardText>
                    <CardText Class="text-info">Rating: @restaurant.Rating/5</CardText>
                </CardBody>
            </Card>
        </a>
    }
</CardGroup>

